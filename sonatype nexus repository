pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK17'
    }

    environment {
        NEXUS_URL = "http://YOUR_NEXUS_SERVER:8081"
        NEXUS_REPO = "maven-releases"
        GROUP_ID = "com.example"
        ARTIFACT_ID = "demo-app"
        VERSION = "1.0"
    }

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/your-repo/demo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Upload to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-creds',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh """
                    curl -v -u $NEXUS_USER:$NEXUS_PASS \
                    --upload-file target/demo-app-1.0.jar \
                    $NEXUS_URL/repository/$NEXUS_REPO/com/example/demo-app/1.0/demo-app-1.0.jar
                    """
                }
            }
        }
    }
}
