cd /opt

# Download Maven
sudo wget https://downloads.apache.org/maven/maven-3/3.9.9/binaries/apache-maven-3.9.9-bin.tar.gz

# Extract
sudo tar -xvzf apache-maven-3.9.9-bin.tar.gz

# Rename
sudo mv apache-maven-3.9.9 maven

# Set environment variables
echo 'export M2_HOME=/opt/maven' | sudo tee -a /etc/profile
echo 'export PATH=$M2_HOME/bin:$PATH' | sudo tee -a /etc/profile

# Reload profile
source /etc/profile

# Verify
mvn -version
